# ─── Database ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_NAME=billingos
DB_USER=billingos
DB_PASS=change_me

# ─── Auth ────────────────────────────────────────────────────
# Must be at least 32 characters
JWT_SECRET=change_me_to_a_random_256_bit_string_minimum_32_chars

# ─── MinIO (object storage) ──────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=change_me
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=billingos

# ─── DTE / MH API ────────────────────────────────────────────
MH_API_URL=https://apidte.mh.gob.sv
# For sandbox testing:
# MH_API_URL=https://apidte-testing.mh.gob.sv
DTE_MAX_RETRIES=5
DTE_RETRY_BASE_DELAY=30

# ─── Server ──────────────────────────────────────────────────
SERVER_PORT=8080

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api
