# ─── Database ────────────────────────────────────────────────────────────────
# Used by docker-compose.prod.yml — postgres runs on the internal network
DB_NAME=billingos
DB_USER=billingos
# REQUIRED: replace with a strong password
DB_PASS=change-me-strong-db-password

# ─── MinIO object storage ─────────────────────────────────────────────────────
# REQUIRED: replace with strong credentials
MINIO_ACCESS_KEY=change-me-minio-user
MINIO_SECRET_KEY=change-me-minio-secret-min-8-chars
MINIO_BUCKET=billingos

# ─── Auth ────────────────────────────────────────────────────────────────────
# REQUIRED: random string of at least 32 characters
JWT_SECRET=change-me-random-secret-minimum-32-characters-long

# ─── Admin user (used on first startup) ──────────────────────────────────────
ADMIN_USERNAME=admin
# REQUIRED: replace before deploying
ADMIN_PASSWORD=change-me-admin-password

# ─── Ministerio de Hacienda DTE API ──────────────────────────────────────────
# Test environment  : https://apitest.dtes.mh.gob.sv
# Production        : https://apidte.mh.gob.sv
MH_API_URL=https://apitest.dtes.mh.gob.sv

# REQUIRED for DTE signing — password of the PKCS12 certificate uploaded in Settings > Certificados
DTE_CERTIFICATE_PASSWORD=
